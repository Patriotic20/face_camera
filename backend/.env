POSTGRES_USER=face_camera_user
POSTGRES_PASSWORD=face_camera_password
POSTGRES_DB=face_camera_db

APP_CONFIG__DATABASE__URL=postgresql+asyncpg://face_camera_user:face_camera_password@localhost:5432/face_camera_db
APP_CONFIG__DATABASE__TEST_URL=postgresql+asyncpg://face_camera_user:face_camera_password@localhost:5432/face_camera_test_db
APP_CONFIG__DATABASE__ECHO=false
APP_CONFIG__DATABASE__ECHO_POOL=false
APP_CONFIG__DATABASE__POOL_SIZE=50
APP_CONFIG__DATABASE__MAX_OVERFLOW=10

APP_CONFIG__SERVER__APP_PATH=/app
APP_CONFIG__SERVER__HOST=0.0.0.0
APP_CONFIG__SERVER__PORT=8000

APP_CONFIG__JWT__ACCESS_TOKEN_SECRET=your_access_token_secret_here
APP_CONFIG__JWT__REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
APP_CONFIG__JWT__ACCESS_TOKEN_EXPIRES_MINUTES=30
APP_CONFIG__JWT__REFRESH_TOKEN_EXPIRES_DAYS=7
APP_CONFIG__JWT__ALGORITHM=HS256

APP_CONFIG__SCHEDULER__MORNING_HOUR=9
APP_CONFIG__SCHEDULER__MORNING_MINUTE=0
APP_CONFIG__SCHEDULER__EVENING_HOUR=18
APP_CONFIG__SCHEDULER__EVENING_MINUTE=0